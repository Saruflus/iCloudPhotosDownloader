# Copy to .env and fill in. .env is git-ignored (it holds secrets).

# Existing Postgres on the NAS — use a DEDICATED database (icloud_sync), not shared tables.
# Plain postgresql:// is fine; the app derives the asyncpg/psycopg drivers itself (D1).
DATABASE_URL=postgresql://user:pass@192.168.x.x:5432/icloud_sync

# Existing Redis on the NAS (pub/sub, locks, thumbnail cache — NOT the iCloud session)
REDIS_URL=redis://192.168.x.x:6379/0

# Filesystem (inside the container)
DOWNLOAD_BASE_PATH=/downloads
ICLOUD_CONFIG_DIR=/config

# Behaviour
DOWNLOAD_CONCURRENCY=4
MAX_RETRIES=3
LOCAL_TIMEZONE=Europe/London
THUMBNAIL_CACHE_TTL=604800

# Optional defense-in-depth on a LAN: require header X-Sync-Secret on /api and /ws
# API_SHARED_SECRET=change-me
